rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
    }

    match /applications/{applicationId} {
      // Clients can read their own application (tracker, appointment,
      // checklist, notes) but only admins can write to it after creation —
      // status, appointment, and checklist are strictly admin-driven.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /documents/{documentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /notifications/{notificationId} {
      // Admins can also read a client's notifications, to show the
      // per-application activity feed on the admin side.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
    }

    match /tourPackages/{packageId} {
      // Publicly readable (the marketing site browses these with no auth) —
      // the app only *queries* publishStatus == "Active" ones for public
      // pages, so Draft/Archived stay effectively unlisted without needing
      // per-document rule complexity. Only admins can write.
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Public lead-capture forms (Contact page, package booking inquiries).
    // Writes go exclusively through the /api/public-submit server route,
    // which verifies reCAPTCHA and writes via the Firebase Admin SDK
    // (bypasses these rules entirely) — so direct client writes are denied
    // here to stop bots from writing straight to Firestore.
    match /inquiries/{inquiryId} {
      allow create: if false;
      allow read: if isAdmin();
    }

    match /bookingLeads/{leadId} {
      allow create: if false;
      allow read: if isAdmin();
    }

    // Public reviews (home page + /reviews). Writes go exclusively through
    // /api/public-submit (reCAPTCHA-verified, Admin SDK) — direct client
    // writes are denied so a bot can't spam fake reviews straight to
    // Firestore. Reads are public since the whole point is displaying them.
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if false;
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
